---
import { site } from '../../data/site';
import logo from '../../assets/footer/logo.svg';
import libro from '../../assets/footer/libro.svg';
import facebook from '../../assets/footer/facebook.svg';
import instagram from '../../assets/footer/instagram.svg';
import tiktok from '../../assets/footer/tiktok.svg';
import whatsapp from '../../assets/footer/whatsapp.svg';

const servicios = [
  { label: 'Preguntas frecuentes', href: '/preguntas-frecuentes' },
  { label: 'Términos y condiciones', href: '/terminos' },
  { label: 'Políticas de privacidad', href: '/privacidad' },
] as const;

const secciones = [
  { label: 'Quiénes somos', href: '/nosotros' },
  { label: 'Nuestras tiendas', href: '/tiendas' },
  { label: 'Blog', href: '/blog' },
] as const;

const socials = [
  { label: 'Facebook', href: site.social.facebook, icon: facebook },
  { label: 'Instagram', href: site.social.instagram, icon: instagram },
  { label: 'TikTok', href: site.social.tiktok, icon: tiktok },
  { label: 'WhatsApp', href: site.social.whatsapp, icon: whatsapp },
] as const;
---

<footer class="bg-cimak-yellow text-cimak-black">
  <!-- Mobile -->
  <div class="container-cimak flex flex-col items-center px-6 py-10 text-center md:hidden">
    <img
      src={logo.src}
      alt="CIMAK"
      class="h-10 w-auto"
      width="89"
      height="34"
    />

    <div class="mt-8 space-y-6">
      <div>
        <h3 class="text-base font-bold">Servicios al cliente</h3>
        <ul class="mt-2 space-y-1 text-sm">
          {
            servicios.map((item) => (
              <li>
                <a href={item.href} class="transition hover:opacity-70">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-base font-bold">Secciones</h3>
        <ul class="mt-2 space-y-1 text-sm">
          {
            secciones.map((item) => (
              <li>
                <a href={item.href} class="transition hover:opacity-70">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-base font-bold">Ubicación y Contacto</h3>
        <ul class="mt-2 space-y-1 text-sm">
          <li>
            <a href={site.phoneHref} class="transition hover:opacity-70">{site.phone}</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="transition hover:opacity-70">{site.email}</a>
          </li>
          <li class="leading-snug">{site.address}</li>
        </ul>
      </div>
    </div>

    <a
      href="/libro-de-reclamaciones"
      class="mt-8 inline-flex w-full max-w-xs items-center justify-center gap-3 rounded-xl bg-cimak-black px-5 py-3.5 text-white transition hover:opacity-90"
    >
      <img
        src={libro.src}
        alt=""
        class="h-6 w-auto brightness-0 invert"
        width="61"
        height="25"
        aria-hidden="true"
      />
      <span class="text-sm font-semibold">Libro de Reclamaciones</span>
    </a>

    <p class="mt-8 text-base font-bold">¡Mantente informado!</p>
    <div class="mt-3 flex items-center justify-center gap-3">
      {
        socials.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={item.label}
            class="transition hover:opacity-80"
          >
            <img src={item.icon.src} alt="" class="h-9 w-9" width="36" height="36" />
          </a>
        ))
      }
    </div>

    <p class="mt-8 max-w-xs text-center text-[0.7rem] leading-relaxed text-cimak-black/90">
      © {new Date().getFullYear()} {site.legalName} RUC: {site.ruc} | Todos los derechos
      reservados
    </p>
  </div>

  <!-- Desktop -->
  <div class="container-cimak hidden py-8 sm:py-10 md:block">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-stretch lg:gap-5">
      <div
        class="grid flex-1 grid-cols-1 gap-6 rounded-2xl bg-cimak-black px-6 py-6 text-white sm:grid-cols-3 sm:gap-0 sm:px-8 sm:py-7"
      >
        <div class="sm:border-r sm:border-white/25 sm:pr-6">
          <h3 class="text-sm font-bold sm:text-base">Servicios al cliente</h3>
          <ul class="mt-3 space-y-1.5 text-sm text-white/90">
            {
              servicios.map((item) => (
                <li class="flex gap-2">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-white" aria-hidden="true" />
                  <a href={item.href} class="transition hover:text-cimak-yellow">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="sm:border-r sm:border-white/25 sm:px-6">
          <h3 class="text-sm font-bold sm:text-base">Secciones</h3>
          <ul class="mt-3 space-y-1.5 text-sm text-white/90">
            {
              secciones.map((item) => (
                <li class="flex gap-2">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-white" aria-hidden="true" />
                  <a href={item.href} class="transition hover:text-cimak-yellow">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="sm:pl-6">
          <h3 class="text-sm font-bold sm:text-base">Ubicación y Contacto:</h3>
          <ul class="mt-3 space-y-1.5 text-sm text-white/90">
            <li>
              <a href={site.phoneHref} class="transition hover:text-cimak-yellow">
                {site.phone}
              </a>
            </li>
            <li>
              <a href={`mailto:${site.email}`} class="transition hover:text-cimak-yellow">
                {site.email}
              </a>
            </li>
            <li class="leading-snug">{site.address}</li>
          </ul>
        </div>
      </div>

      <div
        class="h-[200px] w-full overflow-hidden rounded-2xl shadow-md lg:h-auto lg:w-[min(38%,420px)] lg:shrink-0"
      >
        <iframe
          title="Ubicación CIMAK"
          src={site.mapEmbed}
          class="h-full min-h-[200px] w-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>

    <div class="mt-6 flex flex-col items-start justify-between gap-5 sm:mt-7 sm:flex-row sm:items-center">
      <a
        href="/libro-de-reclamaciones"
        class="inline-flex items-center gap-2.5 rounded-md border border-cimak-black px-3 py-2 transition hover:bg-black/5"
      >
        <img
          src={libro.src}
          alt=""
          class="h-6 w-auto"
          width="61"
          height="25"
          aria-hidden="true"
        />
        <span class="text-left text-xs font-semibold leading-tight">
          Libro de<br />Reclamaciones
        </span>
      </a>
      <div class="flex flex-wrap items-center gap-3 sm:gap-4">
        <p class="text-sm font-bold sm:text-base">¡Mantente informado!</p>
        <div class="flex items-center gap-2.5">
          {
            socials.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.label}
                class="transition hover:opacity-80"
              >
                <img
                  src={item.icon.src}
                  alt=""
                  class="h-7 w-7"
                  width="40"
                  height="40"
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-col items-center gap-3 sm:mt-10">
      <img
        src={logo.src}
        alt="CIMAK"
        class="h-9 w-auto sm:h-10"
        width="89"
        height="34"
      />
      <p class="text-center text-[0.7rem] leading-relaxed text-cimak-black/90 sm:text-xs">
        © {new Date().getFullYear()} {site.legalName} RUC: {site.ruc} | Todos los derechos
        reservados
      </p>
    </div>
  </div>
</footer>

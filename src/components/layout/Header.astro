---
import logo from '../../assets/logo/logo.svg';
import { navLinks } from '../../data/navigation';
---

<header class="sticky top-0 z-50 w-full shadow-sm">
  <div class="bg-cimak-yellow">
    <div class="container-cimak flex items-center justify-between py-2.5 sm:py-3.5">
      <a href="/" class="shrink-0">
        <img src={logo.src} alt="CIMAK PERU" width={120} height={44} class="h-8 w-auto sm:h-11" />
      </a>

      <div class="flex items-center gap-4 text-cimak-black sm:gap-5">
        <button type="button" aria-label="Buscar" class="hover:opacity-70">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="sm:h-6 sm:w-6">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3.5-3.5" />
          </svg>
        </button>

        <a href="/cuenta" aria-label="Cuenta" class="hover:opacity-70">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="sm:h-6 sm:w-6">
            <circle cx="12" cy="8" r="4" />
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <nav class="bg-cimak-black text-cimak-white">
    <div class="container-cimak flex items-center justify-between gap-4 py-2.5 sm:gap-6 sm:py-3.5">
      <ul class="hidden md:flex flex-wrap items-center gap-5 text-sm tracking-wide lg:gap-8 lg:text-[15px]">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:text-cimak-yellow transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        type="button"
        class="md:ml-auto text-cimak-white"
        aria-label="Abrir menú"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

---
import catalogoImg from '../../assets/home/catalogo.svg';
import bannerAluzincImg from '../../assets/home/banner-aluzinc.svg';

const slides = [
  {
    src: bannerAluzincImg.src,
    alt: 'Aluzinc para tu techo',
    href: '/productos/aluzinc',
  },
];
---

<section id="promociones" class="reveal-on-scroll w-full" aria-label="Promociones">
  <div class="grid grid-cols-1 items-stretch lg:grid-cols-2">
    <!-- Izquierda: amarillo full bleed; contenido con margen -->
    <a
      href="/catalogo"
      class="group relative hidden items-center bg-cimak-yellow lg:flex"
    >
      <div class="promo-content-left flex w-full items-center gap-6 py-5 pr-10 lg:gap-8">
        <img
          src={catalogoImg.src}
          alt="Catálogo de productos CIMAK"
          class="h-[130px] w-auto shrink-0 rounded-md object-cover shadow-md xl:h-[150px]"
          width="120"
          height="150"
        />

        <div class="flex min-w-0 flex-col items-start gap-3">
          <h2 class="text-xl font-extrabold uppercase leading-tight tracking-tight text-cimak-black xl:text-2xl">
            Catálogo <br> de productos
          </h2>
          <span class="inline-block bg-cimak-black px-5 py-1.5 text-sm font-bold uppercase tracking-wider text-white">
            Ver
          </span>
        </div>

        <span
          class="ml-auto flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-cimak-black text-white transition group-hover:scale-105"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </span>
      </div>
    </a>

    <!-- Derecha: imagen completa, sin recortar -->
    <div id="promo-carousel" class="relative overflow-hidden bg-[#2a6aa8]" data-slides={slides.length}>
      {slides.map((slide, index) => (
        <a
          href={slide.href}
          class:list={[
            'promo-slide block w-full transition-opacity duration-500',
            index === 0 ? 'relative z-10 opacity-100' : 'pointer-events-none absolute inset-0 z-0 opacity-0',
          ]}
          data-index={index}
          aria-hidden={index !== 0}
        >
          <img
            src={slide.src}
            alt={slide.alt}
            class="block h-auto w-full"
            width="900"
            height="280"
          />
        </a>
      ))}

      {slides.length > 1 && (
        <div class="absolute bottom-3 right-4 z-20 flex gap-2">
          {slides.map((_, index) => (
            <button
              type="button"
              class:list={[
                'promo-dot h-2.5 w-2.5 rounded-full transition',
                index === 0 ? 'bg-white' : 'bg-white/40',
              ]}
              data-index={index}
              aria-label={`Ir al slide ${index + 1}`}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .promo-content-left {
    padding-left: var(--spacing-gutter);
  }

  @media (min-width: 1600px) {
    .promo-content-left {
      padding-left: calc((100vw - var(--container-cimak)) / 2 + var(--spacing-gutter));
    }
  }
</style>

{slides.length > 1 && (
  <script>
    const root = document.getElementById('promo-carousel');
    if (root) {
      const slides = [...root.querySelectorAll('.promo-slide')];
      const dots = [...root.querySelectorAll('.promo-dot')];
      let current = 0;
      let timer;

      const show = (index) => {
        current = index;
        slides.forEach((slide, i) => {
          const active = i === index;
          slide.classList.toggle('opacity-100', active);
          slide.classList.toggle('z-10', active);
          slide.classList.toggle('relative', active);
          slide.classList.toggle('opacity-0', !active);
          slide.classList.toggle('z-0', !active);
          slide.classList.toggle('absolute', !active);
          slide.classList.toggle('inset-0', !active);
          slide.classList.toggle('pointer-events-none', !active);
          slide.setAttribute('aria-hidden', String(!active));
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('bg-white', i === index);
          dot.classList.toggle('bg-white/40', i !== index);
        });
      };

      const next = () => show((current + 1) % slides.length);
      const start = () => {
        timer = window.setInterval(next, 4500);
      };

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          window.clearInterval(timer);
          show(Number(dot.dataset.index));
          start();
        });
      });

      start();
    }
  </script>
)}

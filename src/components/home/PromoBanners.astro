---
import catalogoImg from '../../assets/home/catalogo.svg';
import bannerAluzincImg from '../../assets/home/banner-aluzinc.svg';

/**
 * Carrusel derecho: agrega más imágenes en assets/home
 * y súmalas aquí (banner-2.jpg, banner-3.jpg, etc.)
 */
const slides = [
  {
    src: bannerAluzincImg.src,
    alt: 'Aluzinc para tu techo',
    href: '/productos/aluzinc',
  },
  // {
  //   src: banner2.src,
  //   alt: 'UPVC para tu techo',
  //   href: '/productos/upvc',
  // },
];
---

<section id="promociones" class="reveal-on-scroll w-full" aria-label="Promociones">
  <div class="grid grid-cols-1 items-stretch lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
    <!-- Catálogo: solo desktop -->
    <a
      href="/catalogo"
      class="group relative hidden min-h-0 items-center gap-3 bg-cimak-yellow px-4 py-4 sm:gap-6 sm:px-8 sm:py-5 lg:flex lg:gap-8 lg:px-10"
    >
      <img
        src={catalogoImg.src}
        alt="Catálogo de productos CIMAK"
        class="h-24 w-auto shrink-0 rounded-md object-cover shadow-md sm:h-36 lg:h-[160px]"
        width="130"
        height="auto"
      />

      <div class="flex flex-1 flex-col items-start gap-2 pr-8 sm:gap-3 sm:pr-10 lg:gap-4">
        <h2 class="max-w-[11ch] text-lg font-extrabold uppercase leading-[1.05] tracking-tight text-cimak-black sm:text-2xl lg:text-[2rem]">
          Catálogo de productos
        </h2>
        <span class="inline-block bg-cimak-black px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-white sm:px-5 sm:py-2 sm:text-sm">
          Ver
        </span>
      </div>

      <span
        class="absolute right-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-cimak-black text-white transition group-hover:scale-105 sm:right-5 sm:h-11 sm:w-11 lg:right-7"
        aria-hidden="true"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    </a>

    <!-- Derecha: carrusel de imágenes -->
    <div
      id="promo-carousel"
      class="relative overflow-hidden bg-[#2a6aa8]"
      data-slides={slides.length}
    >
      <!-- Mantiene la altura del bloque -->
      <img
        src={slides[0].src}
        alt=""
        class="invisible block h-auto w-full"
        width="900"
        height="280"
        aria-hidden="true"
      />

      {slides.map((slide, index) => (
        <a
          href={slide.href}
          class:list={[
            'promo-slide absolute inset-0 block transition-opacity duration-500',
            index === 0 ? 'z-10 opacity-100' : 'pointer-events-none z-0 opacity-0',
          ]}
          data-index={index}
          aria-hidden={index !== 0}
        >
          <img
            src={slide.src}
            alt={slide.alt}
            class="h-full w-full object-cover object-center"
            width="900"
            height="280"
          />
        </a>
      ))}

      {slides.length > 1 && (
        <div class="absolute bottom-3 right-4 z-20 flex gap-2" role="tablist" aria-label="Slides">
          {slides.map((_, index) => (
            <button
              type="button"
              class:list={[
                'promo-dot h-2.5 w-2.5 rounded-full transition',
                index === 0 ? 'bg-white' : 'bg-white/40',
              ]}
              data-index={index}
              aria-label={`Ir al slide ${index + 1}`}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</section>

{slides.length > 1 && (
  <script>
    const root = document.getElementById('promo-carousel');
    if (root) {
      const slides = [...root.querySelectorAll('.promo-slide')];
      const dots = [...root.querySelectorAll('.promo-dot')];
      let current = 0;
      let timer;

      const show = (index) => {
        current = index;
        slides.forEach((slide, i) => {
          const active = i === index;
          slide.classList.toggle('opacity-100', active);
          slide.classList.toggle('z-10', active);
          slide.classList.toggle('opacity-0', !active);
          slide.classList.toggle('z-0', !active);
          slide.classList.toggle('pointer-events-none', !active);
          slide.setAttribute('aria-hidden', String(!active));
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('bg-white', i === index);
          dot.classList.toggle('bg-white/40', i !== index);
        });
      };

      const next = () => show((current + 1) % slides.length);

      const start = () => {
        timer = window.setInterval(next, 4500);
      };

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          window.clearInterval(timer);
          show(Number(dot.dataset.index));
          start();
        });
      });

      start();
    }
  </script>
)}

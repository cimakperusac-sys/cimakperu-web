---
import videoFondo from '../../assets/fondo/video-fondo.mp4';
---

<section
  id="hero"
  class="relative w-full overflow-hidden bg-cimak-black"
  aria-label="Video principal"
>
  <video
    class="block h-auto w-full"
    src={videoFondo}
    autoplay
    muted
    loop
    playsinline
  ></video>

  <a
    href="#promociones"
    class="absolute bottom-4 left-1/2 z-20 flex -translate-x-1/2 flex-col items-center gap-1.5 text-white no-underline sm:bottom-8 sm:gap-2"
    aria-label="Desplázate hacia abajo"
  >
    <span class="text-[10px] font-semibold uppercase tracking-[0.2em] opacity-90 sm:text-xs">
      Scroll
    </span>
    <span class="scroll-hint flex h-8 w-5 items-start justify-center rounded-full border-2 border-white/80 p-1 sm:h-10 sm:w-6 sm:p-1.5">
      <span class="scroll-hint-dot block h-1.5 w-1.5 rounded-full bg-white"></span>
    </span>
    <svg
      class="scroll-hint-arrow h-4 w-4 opacity-90 sm:h-5 sm:w-5"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="m6 9 6 6 6-6" />
    </svg>
  </a>
</section>
